# Open Brain — Claude Session Import
# Copy this file to .env and fill in your values.
# Then: export $(cat .env | xargs)   (bash)
#  or:  Get-Content .env | ForEach-Object { ... }   (PowerShell — see run-daily-sync.ps1)

# Supabase (from your Open Brain setup — Credential Tracker)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter (for LLM summarization and embedding generation)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override session source paths.
# Defaults work for stock Windows installs of Claude Code + Cowork.
# CLAUDE_CODE_SESSIONS_DIR=C:\Users\YOU\.claude\projects
# COWORK_SESSIONS_DIR=C:\Users\YOU\AppData\Roaming\Claude\local-agent-mode-sessions
